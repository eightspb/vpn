# Copy to .env and fill with your values.
# Do not commit .env or vpn-output/keys.env.

# Common
ADGUARD_PASS=change_me_strong_password
CLIENT_IP=10.9.0.2

# VPS1
VPS1_IP=89.169.179.233
VPS1_USER=root
VPS1_KEY=.ssh/id_rsa
VPS1_PASS=

# VPS2
VPS2_IP=38.135.122.81
VPS2_USER=root
VPS2_KEY=.ssh/id_rsa
VPS2_PASS=

# Monitoring alert thresholds (optional)
ALERT_LOAD_WARN_PCT=120
ALERT_LOAD_CRIT_PCT=180
ALERT_MEM_WARN_PCT=80
ALERT_MEM_CRIT_PCT=90
ALERT_SWAP_WARN_MB=64
ALERT_SWAP_CRIT_MB=256
ALERT_CONNTRACK_WARN_PCT=70
ALERT_CONNTRACK_CRIT_PCT=85

# Example usage:
# source .env
# bash deploy.sh \
#   --vps1-ip "$VPS1_IP" --vps1-user "$VPS1_USER" --vps1-key "$VPS1_KEY" \
#   --vps2-ip "$VPS2_IP" --vps2-user "$VPS2_USER" --vps2-key "$VPS2_KEY" \
#   --client-ip "$CLIENT_IP" --adguard-pass "$ADGUARD_PASS"
